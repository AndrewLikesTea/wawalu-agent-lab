{
  "version": 1,
  "branch_prefix": "agent/",
  "max_files_changed": 30,
  "max_diff_lines": 2000,
  "max_agent_turns": 20,
  "allowed_workspace_root": ".agent/worktrees",
  "forbidden_paths": [
    ".github/workflows/",
    ".github/CODEOWNERS",
    ".agent-policy.json",
    "src/agents.html",
    "src/agents.js",
    "src/agents.css",
    "src/agent-demo-data.json",
    "tests/agent-observatory.test.js",
    "runner/autonomous.py",
    "runner/delivery.py",
    "runner/local_database.py",
    "config/autonomy.example.json",
    "config/team-behaviors.json",
    "runner/simulation.py",
    "scripts/manage_autonomy.py",
    ".secrets/",
    "wrangler.toml"
  ],
  "forbidden_commands": [
    "git push --force",
    "git push origin main",
    "gh pr merge",
    "gh secret",
    "sqlite3",
    "wrangler d1",
    "wrangler secret",
    "wrangler pages deploy",
    "rm -rf"
  ],
  "local_databases": {
    "enabled": true,
    "directory": ".agent/local-databases",
    "name_prefix": "wawalu-agent-lab-",
    "max_name_length": 64,
    "migration_directory": "migrations",
    "allowed_operations": ["create", "migrate", "check", "path"],
    "destructive_sql_allowed": false,
    "symlinks_allowed": false
  }
}
