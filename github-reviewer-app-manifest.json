{
  "name": "Wawalu Synthetic Reviewer",
  "url": "https://labs.wawalu.org",
  "hook_attributes": {"url": "https://labs.wawalu.org/api/github/reviewer-webhook", "active": false},
  "redirect_url": "http://127.0.0.1:8790/github-app/callback",
  "callback_urls": ["http://127.0.0.1:8790/github-app/callback"],
  "public": false,
  "default_permissions": {
    "contents": "read",
    "pull_requests": "write",
    "metadata": "read",
    "checks": "read"
  },
  "default_events": ["pull_request"]
}
